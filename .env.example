# ============================================
# Client Portal Stack — Environment Variables
# ============================================

# Database (PostgreSQL)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USER=cloudcomputer
DB_PASSWORD=your-secure-password
DB_NAME=client_portal

# Security
JWT_SECRET=generate-a-64-char-random-string-here

# Stripe (live key for production)
STRIPE_SECRET_KEY=sk_live_...

# Resend (email service)
RESEND_API_KEY=re_...

# Auto-create admin on first boot (optional)
ADMIN_NAME=Admin
ADMIN_EMAIL=you@advancedmarketing.co
ADMIN_PASSWORD=change-me-immediately
